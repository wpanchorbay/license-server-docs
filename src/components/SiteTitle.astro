---
const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex">
	<span class="license-navbar-mark" aria-hidden="true"></span>
	<span translate="no">{siteTitle}</span>
</a>

<style>
	@layer starlight.core {
		.site-title {
			align-items: center;
			gap: var(--sl-nav-gap);
			font-size: var(--sl-text-h4);
			font-weight: 600;
			color: var(--sl-color-text-accent);
			text-decoration: none;
			white-space: nowrap;
			min-width: 0;
		}

		.site-title span:last-child {
			overflow: hidden;
		}

		.license-navbar-mark {
			display: block;
			flex: 0 0 auto;
			width: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
			height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
			background: #5865f2;
			mask: url('/license-server-for-woocommerce/assets/license-server-logo-inner.svg') center / contain no-repeat;
			-webkit-mask: url('/license-server-for-woocommerce/assets/license-server-logo-inner.svg') center / contain no-repeat;
		}
	}
</style>
